# ============================================================
# Zomeo.ai Backend — Environment Variables
# ============================================================

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (required for AI features)
OPENAI_API_KEY=sk-...

# Redis / Upstash (required for BullMQ job queues + embedding cache)
UPSTASH_REDIS_URL=rediss://your-upstash-url

# Stripe (required for billing)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_CLINIC=price_...
STRIPE_PRICE_INSTITUTION=price_...
STRIPE_PRICE_RESEARCHER=price_...

# CCAvenue (required for India payments)
CCAVENUE_MERCHANT_ID=your-merchant-id
CCAVENUE_ACCESS_CODE=your-access-code
CCAVENUE_WORKING_KEY=your-working-key

# Twilio (required for SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1234567890

# Resend (required for email)
RESEND_API_KEY=re_...

# Sentry (optional — error tracking)
SENTRY_DSN=https://...@sentry.io/...

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
JWT_SECRET=your-jwt-secret-min-32-chars
